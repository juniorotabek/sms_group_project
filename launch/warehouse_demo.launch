<launch>
  <node pkg="smart_warehouse_robot" type="task_publisher_node.py" name="task_publisher" output="screen">
    <param name="publish_interval_seconds" value="5.0" />
    <param name="auto_publish_sample_tasks" value="true" />
  </node>

  <node pkg="smart_warehouse_robot" type="task_queue_manager_node.py" name="task_queue_manager" output="screen">
    <param name="robot_name" value="warehouse_bot_01" />
    <param name="auto_process_tasks" value="true" />
    <param name="completion_cycles" value="2" />
  </node>

  <node pkg="smart_warehouse_robot" type="waypoint_goal_publisher_node.py" name="waypoint_goal_publisher" output="screen" />

  <node pkg="smart_warehouse_robot" type="path_progress_monitor_node.py" name="path_progress_monitor" output="screen">
    <param name="navigation_step_percent" value="25.0" />
    <param name="navigation_update_seconds" value="2.0" />
  </node>

  <node pkg="smart_warehouse_robot" type="obstacle_detector_node.py" name="obstacle_detector" output="screen">
    <param name="detection_interval_seconds" value="2.0" />
    <param name="simulation_enabled" value="true" />
    <param name="default_zone" value="storage_a" />
  </node>

  <node pkg="smart_warehouse_robot" type="emergency_stop_node.py" name="emergency_stop" output="screen" />

  <node pkg="smart_warehouse_robot" type="battery_publisher_node.py" name="battery_publisher" output="screen">
    <param name="robot_name" value="warehouse_bot_01" />
    <param name="publish_interval_seconds" value="3.0" />
    <param name="start_percentage" value="100.0" />
    <param name="battery_drain_percent" value="5.0" />
    <param name="battery_charge_percent" value="10.0" />
    <param name="start_zone" value="receiving" />
  </node>

  <node pkg="smart_warehouse_robot" type="charging_controller_node.py" name="charging_controller" output="screen">
    <param name="low_battery_threshold" value="25.0" />
    <param name="critical_battery_threshold" value="10.0" />
    <param name="publish_navigation_goal" value="true" />
  </node>

  <node pkg="smart_warehouse_robot" type="package_handler_node.py" name="package_handler" output="screen">
    <param name="robot_name" value="warehouse_bot_01" />
    <param name="default_source_zone" value="storage_a" />
    <param name="default_destination_zone" value="shipping" />
    <param name="auto_create_package_on_pickup" value="true" />
  </node>

  <node pkg="smart_warehouse_robot" type="status_publisher_node.py" name="status_publisher" output="screen">
    <param name="robot_name" value="warehouse_bot_01" />
    <param name="publish_interval_seconds" value="2.0" />
    <param name="start_zone" value="receiving" />
  </node>

  <node pkg="smart_warehouse_robot" type="diagnostic_logger_node.py" name="diagnostic_logger" output="screen">
    <param name="robot_name" value="warehouse_bot_01" />
    <param name="log_interval_seconds" value="5.0" />
    <param name="max_events" value="100" />
  </node>
</launch>
