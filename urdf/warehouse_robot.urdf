<?xml version="1.0"?>
<robot name="warehouse_robot">
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="18.0" />
      <inertia ixx="1.2" ixy="0.0" ixz="0.0" iyy="2.0" iyz="0.0" izz="2.4" />
    </inertial>
    <visual>
      <origin xyz="0 0 0.06" rpy="0 0 0" />
      <geometry>
        <box size="0.60 0.42 0.12" />
      </geometry>
      <material name="blue">
        <color rgba="0.12 0.32 0.68 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.06" rpy="0 0 0" />
      <geometry>
        <box size="0.60 0.42 0.12" />
      </geometry>
    </collision>
  </link>

  <link name="mast_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="2.0" />
      <inertia ixx="0.05" ixy="0.0" ixz="0.0" iyy="0.05" iyz="0.0" izz="0.02" />
    </inertial>
    <visual>
      <origin xyz="0 0 0.12" rpy="0 0 0" />
      <geometry>
        <box size="0.10 0.10 0.24" />
      </geometry>
      <material name="gray">
        <color rgba="0.35 0.35 0.35 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.12" rpy="0 0 0" />
      <geometry>
        <box size="0.10 0.10 0.24" />
      </geometry>
    </collision>
  </link>

  <link name="sensor_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.5" />
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />
    </inertial>
    <visual>
      <origin xyz="0.18 0 0.24" rpy="0 0 0" />
      <geometry>
        <cylinder length="0.06" radius="0.04" />
      </geometry>
      <material name="orange">
        <color rgba="0.92 0.45 0.10 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0.18 0 0.24" rpy="0 0 0" />
      <geometry>
        <cylinder length="0.06" radius="0.04" />
      </geometry>
    </collision>
  </link>

  <link name="caster_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.3" />
      <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.005" />
    </inertial>
    <visual>
      <origin xyz="-0.22 0 -0.03" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.04" />
      </geometry>
      <material name="black">
        <color rgba="0.08 0.08 0.08 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="-0.22 0 -0.03" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.04" />
      </geometry>
    </collision>
  </link>

  <joint name="base_to_mast" type="fixed">
    <parent link="base_link" />
    <child link="mast_link" />
    <origin xyz="0.05 0 0.12" rpy="0 0 0" />
  </joint>

  <joint name="mast_to_sensor" type="fixed">
    <parent link="mast_link" />
    <child link="sensor_link" />
    <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
  </joint>

  <joint name="base_to_caster" type="fixed">
    <parent link="base_link" />
    <child link="caster_link" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>

  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
  </gazebo>

  <gazebo reference="mast_link">
    <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo reference="sensor_link">
    <material>Gazebo/Orange</material>
  </gazebo>

  <gazebo reference="caster_link">
    <material>Gazebo/Black</material>
  </gazebo>
</robot>